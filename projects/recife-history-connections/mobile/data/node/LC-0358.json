{"id":"LC-0358","name":"Cais do Sertão","type":"local","subtype":"Museu","description":"O Centro Cultural Cais do Sertão é um dos museus mais modernos e imersivos do Brasil, instalado à beira-mar no antigo Armazém 10 do Porto do Recife. O espaço propõe uma viagem poética e sensorial pela cultura nordestina, tendo como fio condutor a vida e a obra de Luiz Gonzaga, o Rei do Baião.","de":"The Centro Cultural Cais do Sertão is one of the most modern and immersive museums in Brazil, set on the seafront in the former Armazém 10 of the Porto do Recife. The space offers a poetic and sensory journey through Northeastern culture, using the life and work of Luiz Gonzaga, the Rei do Baião, as its guiding thread.","period":"","reference_location":"Recife Antigo","municipality":"Recife","neighborhood":"Recife Antigo","image":"","aliases":["Museu Cais do Sertão"],"sources":[{"id":"FT-0005","title":"https://pt.wikipedia.org/wiki/Museu_Cais_do_Sert%C3%A3o","source_type":"url","author":"","year":"","url":"https://pt.wikipedia.org/wiki/Museu_Cais_do_Sert%C3%A3o","notes":""},{"id":"FT-0001","title":"https://antonioaurel.github.io/data/data-visualization/recife-history-connections/pages/sources.html","source_type":"url","author":"","year":"","url":"https://antonioaurel.github.io/data/data-visualization/recife-history-connections/pages/sources.html","notes":""}],"edges":[{"target_id":"LC-AUS-0023","target_name":"Bacia do Pina","target_type":"local","type":"unresolved","strength":1},{"target_id":"LC-0524","target_name":"Cine Teatro Apolo","target_type":"local","type":"unresolved","strength":1},{"target_id":"PE-AUS-0066","target_name":"Dominguinhos","target_type":"personagem","type":"person","strength":1},{"target_id":"PE-AUS-0080","target_name":"Francisco Brennand","target_type":"personagem","type":"unresolved","strength":1},{"target_id":"LC-0183","target_name":"Instituto Ricardo Brennand","target_type":"local","type":"unresolved","strength":1},{"target_id":"PE-AUS-0117","target_name":"Lu