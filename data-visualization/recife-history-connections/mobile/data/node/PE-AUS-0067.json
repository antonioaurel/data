{"id":"PE-AUS-0067","name":"Duarte Coelho Pereira","type":"person","subtype":"Personagem","description":"Duarte Coelho Pereira foi o primeiro donatário da Capitania de Pernambuco e figura central na fundação de Olinda. Suas conexões com o Alto da Sé, as capitanias hereditárias e os povos originários situam o início da colonização portuguesa no território pernambucano.","period":"","reference_location":"Prazeres","municipality":"Jaboatão","neighborhood":"Prazeres","image":"","aliases":[],"sources":[{"id":"FT-0001","title":"https://antonioaurel.github.io/data/data-visualization/recife-history-connections/pages/sources.html","source_type":"url","author":"","year":"","url":"https://antonioaurel.github.io/data/data-visualization/recife-history-connections/pages/sources.html","notes":""}],"edges":[{"target_id":"LC-0441","target_name":"Alto da Sé","target_type":"place","type":"person","strength":1},{"target_id":"FH-0069","target_name":"Capitanias Hereditárias","target_type":"historical_fact","type":"person","strength":1},{"target_id":"FH-0182","target_name":"Povos Originários (Índios)","target_type":"historical_fact","type":"person","strength":1}]}