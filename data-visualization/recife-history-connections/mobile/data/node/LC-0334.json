{"id":"LC-0334","name":"Sítio do Valença (Sítio Sabiá)","type":"place","subtype":"Sítio Histórico","description":"Sitio do Valença é um sitio histórico localizado em Madalena, no Recife/Pernambuco. Relaciona-se a Mercado da Madalena e Irmãos Valença, indicando sua função como ponto de articulação entre território, memória e vida urbana. Sua presença ajuda a compreender como espaços públicos, edifícios, instituições e equipamentos acumulam camadas de uso social, homenagens e transformações ao longo do tempo. Sitio do Valença funciona como referência para compreender a experiência cotidiana do Recife com processos históricos, culturais e políticos mais amplos.","period":"","reference_location":"Madalena","municipality":"Recife","neighborhood":"Madalena","image":"","has_geo":false,"aliases":["Sítio do Valença"],"sources":[{"id":"FT-0001","title":"https://antonioaurel.github.io/data/data-visualization/recife-history-connections/pages/sources.html","source_type":"url","author":"","year":"","url":"https://antonioaurel.github.io/data/data-visualization/recife-history-connections/pages/sources.html","notes":""}],"edges":[{"target_id":"LC-0030","target_name":"Avenida Caxangá","target_type":"place","type":"local","strength":1},{"target_id":"LC-0431","target_name":"Casa de Clarice Lispector","target_type":"place","type":"local","strength":1},{"target_id":"LC-0385","target_name":"Cemitério dos Ingleses","target_type":"place","type":"local","strength":1},{"target_id":"LC-0085","target_name":"Clube Internacional do Recife","target_type":"place","type":"local","strength":1},{"target_id":"LC-0118","target_name":"Edifício Acaiaca","target_type":"place","type":"local","strength":1},{"target_id":"LC-0115","target_name":"Edifício Holiday","target_type":"place","type":"local","strength":1},{"target_id":"LC-0125","target_name":"Estrada dos Remédios","target_type":"place","type":"local","strength":1},{"target_id":"LC-0395","target_name":"Hotel Central","target_type":"place","type":"local"