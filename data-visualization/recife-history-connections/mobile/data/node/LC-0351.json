{"id":"LC-0351","name":"Viaduto Capitão Temudo","type":"local","subtype":"Viaduto","description":"Viaduto Capitão Temudo é um viaduto localizado em São José, no Recife/Pernambuco. Relaciona-se a Capitão Temudo e Avenida Agamenon Magalhães, indicando sua função como ponto de articulação entre território, memória e vida urbana. Sua presença ajuda a compreender como espaços públicos, edifícios, instituições e equipamentos acumulam camadas de uso social, homenagens e transformações ao longo do tempo. Viaduto Capitão Temudo funciona como referência para compreender a experiência cotidiana do Recife com processos históricos, culturais e políticos mais amplos.","period":"","reference_location":"São José","municipality":"Recife","neighborhood":"São José","image":"","aliases":[],"sources":[{"id":"FT-0001","title":"https://antonioaurel.github.io/data/data-visualization/recife-history-connections/pages/sources.html","source_type":"url","author":"","year":"","url":"https://antonioaurel.github.io/data/data-visualization/recife-history-connections/pages/sources.html","notes":""}],"edges":[{"target_id":"LC-0026","target_name":"Avenida Agamenon Magalhães","target_type":"local","type":"local","strength":1},{"target_id":"LC-0031","target_name":"Avenida Dantas Barreto","target_type":"local","type":"local","strength":1},{"target_id":"LC-0063","target_name":"Cais José Estelita","target_type":"local","type":"local","strength":1},{"target_id":"LC-0064","target_name":"Cais Martins de Barros","target_type":"local","type":"local","strength":1},{"target_id":"LC-0370","target_name":"Cais de Santa Rita","target_type":"local","type":"local","strength":1},{"target_id":"LC-0066","target_name":"Camelódromo","target_type":"local","type":"local","strength":1},{"target_id":"PE-AUS-0042","target_name":"Capitão Temudo","target_type":"personagem","type":"person","strength":1},{"target_id":"LC-0075","target_name":"Casa da Cultura","target_type":"local","type":"local","strength":1},{"target_id":"LC-0385","