{"id":"LC-0239","name":"Museu da Abolição (Casarão de João Alfredo)","type":"place","subtype":"Museu","description":"O Museu da Abolição, instalado no antigo casarão associado a João Alfredo, no bairro da Madalena, é uma instituição dedicada à memória da escravidão, da resistência negra e do processo abolicionista no Brasil. O espaço preserva debates sobre a formação social brasileira, as violências da escravidão e as lutas por liberdade e cidadania. conecta-se à Avenida Caxangá, a João Alfredo e a outros registros da memória política e social pernambucana, funcionando como ponto de reflexão sobre abolição, patrimônio e desigualdade.","period":"","reference_location":"","municipality":"Pernambuco","neighborhood":"","image":"","aliases":["Museu da Abolição"],"sources":[{"id":"FT-0001","title":"https://antonioaurel.github.io/data/data-visualization/recife-history-connections/pages/sources.html","source_type":"url","author":"","year":"","url":"https://antonioaurel.github.io/data/data-visualization/recife-history-connections/pages/sources.html","notes":""}],"edges":[{"target_id":"LC-0030","target_name":"Avenida Caxangá","target_type":"place","type":"local","strength":1},{"target_id":"LC-0075","target_name":"Casa da Cultura","target_type":"place","type":"local","strength":1},{"target_id":"LC-0453","target_name":"Casa dos Bonecos Gigantes do Alto da Sé","target_type":"place","type":"local","strength":1},{"target_id":"LC-0077","target_name":"Castelinho","target_type":"place","type":"local","strength":1},{"target_id":"LC-0085","target_name":"Clube Internacional do Recife","target_type":"place","type":"local","strength":1},{"target_id":"LC-0121","target_name":"Estação Central","target_type":"place","type":"local","strength":1},{"target_id":"LC-0123","target_name":"Estação do Brum","target_type":"place","type":"local","strength":1},{"target_id":"LC-0125","target_name":"Estrada dos Remédios","target_type":"place","type":"local","strength":1},{"target_id":"LC-0146","target_name