{"id":"LC-0422","name":"Basílica de Nossa Senhora da Penha (Igreja da Penha)","type":"place","subtype":"Templo Religioso","description":"A Basílica da Penha é um templo religioso católico romano situado no bairro de São José. Pertence à Ordem dos Frades Menores Capuchinhos. A origem da localização da Basílica da Penha remonta a um pequeno oratório instituído em 1655 pelos franciscanos capuchinhos franceses. O templo atual, contudo, foi construído entre os anos de 1870 e 1882, sendo a única igreja em estilo coríntio do estado de Pernambuco.","period":"","reference_location":"São José","municipality":"Recife","neighborhood":"São José","image":"http://jconlineimagem.ne10.uol.com.br/imagem/galeria/2015/03/06/4218_avulsa/normal/867b587b7c0da5f1af73b47803e60859.jpg","aliases":["Basílica da Penha"],"sources":[{"id":"FT-0001","title":"https://antonioaurel.github.io/data/data-visualization/recife-history-connections/pages/sources.html","source_type":"url","author":"","year":"","url":"https://antonioaurel.github.io/data/data-visualization/recife-history-connections/pages/sources.html","notes":""}],"edges":[{"target_id":"FH-0051","target_name":"Bênção de São Félix","target_type":"historical_fact","type":"historical_event","strength":1},{"target_id":"LC-0068","target_name":"Capela Dourada","target_type":"place","type":"local","strength":1},{"target_id":"LC-0098","target_name":"Convento de Santo Antônio","target_type":"place","type":"local","strength":1},{"target_id":"LC-0101","target_name":"Cruz do Patrão","target_type":"place","type":"local","strength":1},{"target_id":"LC-0165","target_name":"Igreja da Capunga","target_type":"place","type":"local","strength":1},{"target_id":"LC-0166","target_name":"Igreja da Conceição dos Militares","target_type":"place","type":"local","strength":1},{"target_id":"LC-0167","target_name":"Igreja da Madre de Deus","target_type":"place","type":"local","strength":1},{"target_id":"LC-0168","target_name":"Igreja da Várzea (Paróquia Nossa Sra. do Rosá