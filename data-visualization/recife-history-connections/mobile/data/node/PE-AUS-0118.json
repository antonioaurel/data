{"id":"PE-AUS-0118","name":"Mãe Tila","type":"person","subtype":"Personagem","description":"Mãe Tila foi liderança religiosa ligada ao Terreiro de Xambá, tradição afro-brasileira com forte presença em Pernambuco. Sua memória destaca a força das mulheres na preservação de práticas, ritos e comunidades de matriz africana.","period":"","reference_location":"São Benedito","municipality":"Olinda","neighborhood":"São Benedito","image":"","aliases":[],"sources":[{"id":"FT-0001","title":"https://antonioaurel.github.io/data/data-visualization/recife-history-connections/pages/sources.html","source_type":"url","author":"","year":"","url":"https://antonioaurel.github.io/data/data-visualization/recife-history-connections/pages/sources.html","notes":""}],"edges":[{"target_id":"LC-0461","target_name":"O Terreiro de Xambá","target_type":"place","type":"person","strength":1}]}