{"id":"LC-0404","name":"Monte dos Guararapes","type":"place","subtype":"Sítio Histórico","description":"Monte dos Guararapes é um sitio histórico localizado em Jaboatão, no Recife/Pernambuco. Relaciona-se a Batalha dos Guararapes, indicando sua função como ponto de articulação entre território, memória e vida urbana. Sua presença ajuda a compreender como espaços públicos, edifícios, instituições e equipamentos acumulam camadas de uso social, homenagens e transformações ao longo do tempo. Monte dos Guararapes funciona como referência para compreender a experiência cotidiana do Recife com processos históricos, culturais e políticos mais amplos.","period":"","reference_location":"","municipality":"Pernambuco fora do Recife","neighborhood":"","image":"","has_geo":false,"aliases":[],"sources":[{"id":"FT-0001","title":"https://antonioaurel.github.io/data/data-visualization/recife-history-connections/pages/sources.html","source_type":"url","author":"","year":"","url":"https://antonioaurel.github.io/data/data-visualization/recife-history-connections/pages/sources.html","notes":""}],"edges":[{"target_id":"FH-0381","target_name":"Batalha dos Guararapes","target_type":"historical_fact","type":"local","strength":1},{"target_id":"LC-0225","target_name":"Mercado da Madalena","target_type":"place","type":"local","strength":1},{"target_id":"LC-0233","target_name":"Monumento aos Aviadores Portugueses","target_type":"place","type":"local","strength":1},{"target_id":"LC-0238","target_name":"Mural da Batalha dos Guararapes","target_type":"place","type":"local","strength":1},{"target_id":"LC-0382","target_name":"Painel da Batalha dos Guararapes","target_type":"place","type":"local","strength":1},{"target_id":"LC-0373","target_name":"Parque de Dois Irmãos","target_type":"place","type":"local","strength":1},{"target_id":"LC-0391","target_name":"Paço Alfândega","target_type":"place","type":"local","strength":1},{"target_id":"LC-0302","target_name":"Restaurante Dom Pedro","target_type":"pla