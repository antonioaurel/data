{"id":"LC-0061","name":"Cais da Lingueta","type":"place","subtype":"Cais","description":"Cais da Lingueta é um cais localizado em Recife Antigo, no Recife/Pernambuco. Relaciona-se a Cais da Alfandega, Cais José Estelita, Cais do Apolo, Cais Martins de Barros, Fortaleza do Buraco e Porto do Recife, indicando sua função como ponto de articulação entre território, memória e vida urbana. Sua presença ajuda a compreender como espaços públicos, edifícios, instituições e equipamentos acumulam camadas de uso social, homenagens e transformações ao longo do tempo. Cais da Lingueta funciona como referência para compreender a experiência cotidiana do Recife com processos históricos, culturais e políticos mais amplos.","period":"","reference_location":"Recife Antigo","municipality":"Recife","neighborhood":"Recife Antigo","image":"","has_geo":false,"aliases":[],"sources":[{"id":"FT-0001","title":"https://antonioaurel.github.io/data/data-visualization/recife-history-connections/pages/sources.html","source_type":"url","author":"","year":"","url":"https://antonioaurel.github.io/data/data-visualization/recife-history-connections/pages/sources.html","notes":""}],"edges":[{"target_id":"LC-0009","target_name":"Aeroclube de Pernambuco","target_type":"place","type":"local","strength":1},{"target_id":"LC-0010","target_name":"Aeroporto Internacional do Recife","target_type":"place","type":"local","strength":1},{"target_id":"LC-0313","target_name":"Avenida Alfredo Lisboa","target_type":"place","type":"local","strength":1},{"target_id":"LC-0028","target_name":"Avenida Barbosa Lima","target_type":"place","type":"local","strength":1},{"target_id":"LC-0036","target_name":"Avenida Marquês de Olinda","target_type":"place","type":"local","strength":1},{"target_id":"LC-0037","target_name":"Avenida Rio Branco","target_type":"place","type":"local","strength":1},{"target_id":"LC-0409","target_name":"Avenida da Madre de Deus","target_type":"place","type":"local","strength":1},{"target_id":"LC-AUS-0023",