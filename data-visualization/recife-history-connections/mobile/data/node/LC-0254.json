{"id":"LC-0254","name":"Palácio dos Manguinhos","type":"place","subtype":"Templo Religioso","description":"Palacio dos Manguinhos é um templo religioso localizado em Graças, no Recife/Pernambuco. O registro representa a presença da religiosidade, da arquitetura sacra e das práticas devocionais na formação histórica de Pernambuco. aparece associado a Avenida Rui Barbosa, evidenciando como igrejas, conventos e espaços de fé funcionam como pontos de encontro, patrimônio e referência urbana. conecta espiritualidade, arte, sociabilidade e história local.","period":"","reference_location":"Graças","municipality":"Recife","neighborhood":"Graças","image":"","has_geo":false,"aliases":[],"sources":[{"id":"FT-0001","title":"https://antonioaurel.github.io/data/data-visualization/recife-history-connections/pages/sources.html","source_type":"url","author":"","year":"","url":"https://antonioaurel.github.io/data/data-visualization/recife-history-connections/pages/sources.html","notes":""}],"edges":[{"target_id":"LC-0038","target_name":"Avenida Rui Barbosa","target_type":"place","type":"local","strength":1},{"target_id":"LC-0068","target_name":"Capela Dourada","target_type":"place","type":"local","strength":1},{"target_id":"LC-0088","target_name":"Colégio Agnes","target_type":"place","type":"local","strength":1},{"target_id":"LC-0090","target_name":"Colégio Damas","target_type":"place","type":"local","strength":1},{"target_id":"LC-0092","target_name":"Colégio São Luís","target_type":"place","type":"local","strength":1},{"target_id":"LC-0091","target_name":"Colégio Vera Cruz","target_type":"place","type":"local","strength":1},{"target_id":"LC-0098","target_name":"Convento de Santo Antônio","target_type":"place","type":"local","strength":1},{"target_id":"LC-0101","target_name":"Cruz do Patrão","target_type":"place","type":"local","strength":1},{"target_id":"LC-0165","target_name":"Igreja da Capunga","target_type":"place","type":"local","strength":1},{"target_id":"LC-0166","target_name