{"id":"LC-0363","name":"Igreja Basílica de Nossa Senhora do Carmo","type":"local","subtype":"Templo Religioso","description":"Igreja Basílica de Nossa Senhora do Carmo é um templo religioso localizado em São José, no Recife/Pernambuco. O registro representa a presença da religiosidade, da arquitetura sacra e das práticas devocionais na formação histórica de Pernambuco. aparece associado a Praça do Carmo, evidenciando como igrejas, conventos e espaços de fé funcionam como pontos de encontro, patrimônio e referência urbana. conecta espiritualidade, arte, sociabilidade e história local.","period":"","reference_location":"São José","municipality":"Recife","neighborhood":"São José","image":"","aliases":[],"sources":[{"id":"FT-0001","title":"https://antonioaurel.github.io/data/data-visualization/recife-history-connections/pages/sources.html","source_type":"url","author":"","year":"","url":"https://antonioaurel.github.io/data/data-visualization/recife-history-connections/pages/sources.html","notes":""}],"edges":[{"target_id":"LC-0068","target_name":"Capela Dourada","target_type":"local","type":"local","strength":1},{"target_id":"LC-0098","target_name":"Convento de Santo Antônio","target_type":"local","type":"local","strength":1},{"target_id":"LC-0101","target_name":"Cruz do Patrão","target_type":"local","type":"local","strength":1},{"target_id":"LC-0428","target_name":"Igreja Matriz da Boa Vista","target_type":"local","type":"local","strength":1},{"target_id":"LC-0456","target_name":"Igreja N. S. do Rosário dos Homens Pretos de Olinda","target_type":"local","type":"local","strength":1},{"target_id":"LC-0419","target_name":"Igreja Nossa Senhora da Soledade","target_type":"local","type":"local","strength":1},{"target_id":"LC-0165","target_name":"Igreja da Capunga","target_type":"local","type":"local","strength":1},{"target_id":"LC-0166","target_name":"Igreja da Conceição dos Militares","target_type":"local","type":"local","strength":1},{"target_id":"LC-0167","target_name":"I