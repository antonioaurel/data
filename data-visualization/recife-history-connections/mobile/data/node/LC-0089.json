{"id":"LC-0089","name":"Colégio Americano Batista","type":"place","subtype":"Colégio","description":"Colégio Americano Batista é um colégio localizado em Graças, no Recife/Pernambuco. O espaço se relaciona à formação cultural, educacional ou artística de Pernambuco e ajuda a preservar memórias, práticas e experiências coletivas. aparece associado a Igreja da Capunga, Avenida Agamenon Magalhães e Rua Dom Bosco, indicando sua função como registro de conhecimento, sociabilidade e produção cultural. o registro aproxima educação, patrimônio, cultura urbana e trajetórias históricas que atravessam a cidade.","period":"","reference_location":"Graças","municipality":"Recife","neighborhood":"Graças","image":"","has_geo":false,"aliases":[],"sources":[{"id":"FT-0001","title":"https://antonioaurel.github.io/data/data-visualization/recife-history-connections/pages/sources.html","source_type":"url","author":"","year":"","url":"https://antonioaurel.github.io/data/data-visualization/recife-history-connections/pages/sources.html","notes":""}],"edges":[{"target_id":"LC-0006","target_name":"Academia Pernambucana de Letras","target_type":"place","type":"local","strength":1},{"target_id":"LC-0026","target_name":"Avenida Agamenon Magalhães","target_type":"place","type":"local","strength":1},{"target_id":"LC-0038","target_name":"Avenida Rui Barbosa","target_type":"place","type":"local","strength":1},{"target_id":"LC-0071","target_name":"Capunga","target_type":"place","type":"local","strength":1},{"target_id":"LC-0087","target_name":"Clube Português","target_type":"place","type":"local","strength":1},{"target_id":"LC-0088","target_name":"Colégio Agnes","target_type":"place","type":"local","strength":1},{"target_id":"LC-0090","target_name":"Colégio Damas","target_type":"place","type":"local","strength":1},{"target_id":"LC-0368","target_name":"Colégio Salesiano","target_type":"place","type":"local","strength":1},{"target_id":"LC-0092","target_name":"Colégio São Luís","target_type":"place","ty