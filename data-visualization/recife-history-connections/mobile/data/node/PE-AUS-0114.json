{"id":"PE-AUS-0114","name":"Luís do Rego","type":"person","subtype":"Personagem","description":"Luis do Rego foi governador de Pernambuco após a Revolução de 1817 e figura associada à repressão ao movimento. Suas conexões com o Forte do Picão e com 1817 ajudam a compreender o período de tensão entre poder colonial e projetos autonomistas.","period":"","reference_location":"Recife Antigo","municipality":"","neighborhood":"Recife Antigo","image":"","aliases":["Luis Rego","Luís do Rego"],"sources":[{"id":"FT-0001","title":"https://antonioaurel.github.io/data/data-visualization/recife-history-connections/pages/sources.html","source_type":"url","author":"","year":"","url":"https://antonioaurel.github.io/data/data-visualization/recife-history-connections/pages/sources.html","notes":""}],"edges":[{"target_id":"LC-0438","target_name":"Forte do Picão","target_type":"place","type":"person","strength":1},{"target_id":"FH-0303","target_name":"Revolução Pernambucana de 1817","target_type":"historical_fact","type":"person","strength":1}]}