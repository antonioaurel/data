{"id":"LC-0364","name":"Restaurante Leite","type":"place","subtype":"Bar/Restaurante","description":"Restaurante Leite é um bar/restaurante localizado em São José, no Recife/Pernambuco. Relaciona-se a Praça Joaquim Nabuco, indicando sua função como ponto de articulação entre território, memória e vida urbana. Sua presença ajuda a compreender como espaços públicos, edifícios, instituições e equipamentos acumulam camadas de uso social, homenagens e transformações ao longo do tempo. Restaurante Leite funciona como referência para compreender a experiência cotidiana do Recife com processos históricos, culturais e políticos mais amplos.","period":"","reference_location":"São José","municipality":"Recife","neighborhood":"São José","image":"","has_geo":false,"aliases":[],"sources":[{"id":"FT-0001","title":"https://antonioaurel.github.io/data/data-visualization/recife-history-connections/pages/sources.html","source_type":"url","author":"","year":"","url":"https://antonioaurel.github.io/data/data-visualization/recife-history-connections/pages/sources.html","notes":""}],"edges":[{"target_id":"LC-0031","target_name":"Avenida Dantas Barreto","target_type":"place","type":"local","strength":1},{"target_id":"LC-0502","target_name":"Bar Savoy","target_type":"place","type":"local","strength":1},{"target_id":"LC-0063","target_name":"Cais José Estelita","target_type":"place","type":"local","strength":1},{"target_id":"LC-0064","target_name":"Cais Martins de Barros","target_type":"place","type":"local","strength":1},{"target_id":"LC-0066","target_name":"Camelódromo","target_type":"place","type":"local","strength":1},{"target_id":"LC-0075","target_name":"Casa da Cultura","target_type":"place","type":"local","strength":1},{"target_id":"LC-0118","target_name":"Edifício Acaiaca","target_type":"place","type":"local","strength":1},{"target_id":"LC-0115","target_name":"Edifício Holiday","target_type":"place","type":"local","strength":1},{"target_id":"LC-0395","target_name":"Hotel Central","tar