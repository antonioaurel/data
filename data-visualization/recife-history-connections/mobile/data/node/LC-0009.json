{"id":"LC-0009","name":"Aeroclube de Pernambuco","type":"place","subtype":"Aeroporto","description":"O Aeroclube de Pernambuco foi fundado em 1940, no bairro do Pina, quando o país necessitava de um local específico que formasse pilotos habilitados a comandar aviões de guerra. Além de pista de pouso e decolagem de aviões de pequeno porte, o Aeroclube era um local onde realizam eventos festivos e competitivos. Hoje, contudo, encontra-se desativado.","period":"","reference_location":"Boa Viagem","municipality":"Recife","neighborhood":"Boa Viagem","image":"https://i.ytimg.com/vi/jT2vhMr2Hik/maxresdefault.jpg","aliases":[],"sources":[{"id":"FT-0001","title":"https://antonioaurel.github.io/data/data-visualization/recife-history-connections/pages/sources.html","source_type":"url","author":"","year":"","url":"https://antonioaurel.github.io/data/data-visualization/recife-history-connections/pages/sources.html","notes":""}],"edges":[{"target_id":"LC-0002","target_name":"1 Jardim de Boa Viagem","target_type":"place","type":"local","strength":1},{"target_id":"LC-0003","target_name":"2 Jardim de Boa Viagem","target_type":"place","type":"local","strength":1},{"target_id":"LC-0004","target_name":"3 Jardim de Boa Viagem","target_type":"place","type":"local","strength":1},{"target_id":"LC-0010","target_name":"Aeroporto Internacional do Recife","target_type":"place","type":"local","strength":1},{"target_id":"LC-0027","target_name":"Avenida Barão de Souza Leão","target_type":"place","type":"local","strength":1},{"target_id":"LC-0029","target_name":"Avenida Boa Viagem","target_type":"place","type":"local","strength":1},{"target_id":"LC-0032","target_name":"Avenida Domingos Ferreira","target_type":"place","type":"local","strength":1},{"target_id":"LC-AUS-0023","target_name":"Bacia do Pina","target_type":"place","type":"local","strength":1},{"target_id":"LC-0054","target_name":"Biblioteca Pública do Estado de Pernambuco","target_type":"place","type":"local","strength":1},{"target_id":"L