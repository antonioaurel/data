{"id":"LC-0580","name":"Paço do Frevo","type":"place","subtype":"Museu/Centro Cultural","description":"O Paço do Frevo é o termo correto para a referência às vezes escrita como “Praço do Frevo”. Localizado no coração do Bairro do Recife, é um centro cultural e museu interativo dedicado à salvaguarda, pesquisa e celebração do frevo, ritmo reconhecido como Patrimônio Cultural Imaterial da Humanidade pela UNESCO. Instalado no antigo prédio da Western Telegraph Company, reúne exposições, acervos, música, dança e vivências ligadas ao Carnaval do Recife.","period":"","reference_location":"Recife Antigo","municipality":"Recife","neighborhood":"Recife Antigo","image":"","has_geo":false,"aliases":["Praço do Frevo"],"sources":[{"id":"FT-0006","title":"https://pt.wikipedia.org/wiki/Pa%C3%A7o_do_Frevo","source_type":"url","author":"","year":"","url":"https://pt.wikipedia.org/wiki/Pa%C3%A7o_do_Frevo","notes":""},{"id":"FT-0007","title":"https://en.wikipedia.org/wiki/Frevo","source_type":"url","author":"","year":"","url":"https://en.wikipedia.org/wiki/Frevo","notes":""},{"id":"FT-0001","title":"https://antonioaurel.github.io/data/data-visualization/recife-history-connections/pages/sources.html","source_type":"url","author":"","year":"","url":"https://antonioaurel.github.io/data/data-visualization/recife-history-connections/pages/sources.html","notes":""}],"edges":[{"target_id":"LC-0042","target_name":"Banhistas do Pina","target_type":"place","type":"local","strength":1},{"target_id":"LC-0050","target_name":"Batutas de São José","target_type":"place","type":"local","strength":1},{"target_id":"PE-AUS-0041","target_name":"Capiba","target_type":"person","type":"person","strength":1},{"target_id":"LC-0437","target_name":"Casa do Carnaval - Anexo","target_type":"place","type":"local","strength":1},{"target_id":"LC-0445","target_name":"Clube Carnavalesco Misto Elefante de Olinda","target_type":"place","type":"local","strength":1},{"target_id":"LC-0149","target_name":"Galo da Madrugada",