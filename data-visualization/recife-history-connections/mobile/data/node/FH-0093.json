{"id":"FH-0093","name":"Coluna Prestes","type":"evento","subtype":"Ambiente","description":"Coluna Prestes é um ambiente relacionado à história de Pernambuco. Relaciona-se a Sergio Loreto, Cleto Campelo e Cordeiro de Fárias, formando uma ponte entre acontecimentos, espaços urbanos e personagens públicos. O registro ajuda a contextualizar disputas políticas, mudanças sociais, conflitos, práticas culturais ou transformações ambientais que marcaram a formação pernambucana. Coluna Prestes funciona como eixo narrativo para compreender como eventos coletivos deixam marcas na paisagem, na memória pública e nas conexões entre diferentes pontos do território.","period":"","reference_location":"","municipality":"Pernambuco","neighborhood":"","image":"","aliases":[],"sources":[{"id":"FT-0001","title":"https://antonioaurel.github.io/data/data-visualization/recife-history-connections/pages/sources.html","source_type":"url","author":"","year":"","url":"https://antonioaurel.github.io/data/data-visualization/recife-history-connections/pages/sources.html","notes":""}],"edges":[{"target_id":"FH-0067","target_name":"Cangaço","target_type":"evento","type":"historical_event","strength":1},{"target_id":"FH-0069","target_name":"Capitanias Hereditárias","target_type":"evento","type":"historical_event","strength":1},{"target_id":"PE-AUS-0051","target_name":"Cleto Campelo","target_type":"personagem","type":"person","strength":1},{"target_id":"FH-0094","target_name":"Companhia das Índias Ocidentais","target_type":"evento","type":"historical_event","strength":1},{"target_id":"PE-AUS-0053","target_name":"Cordeiro de Farias","target_type":"personagem","type":"person","strength":1},{"target_id":"FH-0102","target_name":"Cruzeiro do Forte","target_type":"evento","type":"historical_event","strength":1},{"target_id":"FH-0106","target_name":"Desabamentos em Morros do Recife","target_type":"evento","type":"historical_event","strength":1},{"target_id":"FH-0120","target_name":"Esgotamento Sanitário","tar