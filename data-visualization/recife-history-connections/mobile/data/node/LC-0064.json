{"id":"LC-0064","name":"Cais Martins de Barros","type":"place","subtype":"Cais","description":"Cais Martins de Barros é um cais localizado em São José, no Recife/Pernambuco. Relaciona-se a Cais da Alfandega, Cais José Estelita, Cais do Apolo, Cais da Lingueta e Martins de Barros, indicando sua função como ponto de articulação entre território, memória e vida urbana. Sua presença ajuda a compreender como espaços públicos, edifícios, instituições e equipamentos acumulam camadas de uso social, homenagens e transformações ao longo do tempo. Cais Martins de Barros funciona como referência para compreender a experiência cotidiana do Recife com processos históricos, culturais e políticos mais amplos.","period":"","reference_location":"São José","municipality":"Recife","neighborhood":"São José","image":"","has_geo":false,"aliases":[],"sources":[{"id":"FT-0001","title":"https://antonioaurel.github.io/data/data-visualization/recife-history-connections/pages/sources.html","source_type":"url","author":"","year":"","url":"https://antonioaurel.github.io/data/data-visualization/recife-history-connections/pages/sources.html","notes":""}],"edges":[{"target_id":"LC-0009","target_name":"Aeroclube de Pernambuco","target_type":"place","type":"local","strength":1},{"target_id":"LC-0010","target_name":"Aeroporto Internacional do Recife","target_type":"place","type":"local","strength":1},{"target_id":"LC-0031","target_name":"Avenida Dantas Barreto","target_type":"place","type":"local","strength":1},{"target_id":"LC-0377","target_name":"Avenida Nossa Senhora do Carmo","target_type":"place","type":"local","strength":1},{"target_id":"LC-AUS-0023","target_name":"Bacia do Pina","target_type":"place","type":"local","strength":1},{"target_id":"LC-0063","target_name":"Cais José Estelita","target_type":"place","type":"local","strength":1},{"target_id":"LC-0060","target_name":"Cais da Alfândega","target_type":"place","type":"local","strength":1},{"target_id":"LC-0061","target_name":"Cais da Lingueta