{"id":"LC-0131","name":"Favela do Bode","type":"place","subtype":"Bairro","description":"Favela do Bode é um bairro localizado em Pina, no Recife/Pernambuco. Relaciona-se a Maracatu Porto Rico, Avenida Herculano Bandeira e Rio Mar Shopping, indicando sua função como ponto de articulação entre território, memória e vida urbana. Sua presença ajuda a compreender como espaços públicos, edifícios, instituições e equipamentos acumulam camadas de uso social, homenagens e transformações ao longo do tempo. Favela do Bode funciona como referência para compreender a experiência cotidiana do Recife com processos históricos, culturais e políticos mais amplos.","period":"","reference_location":"Pina","municipality":"Recife","neighborhood":"Pina","image":"","aliases":[],"sources":[{"id":"FT-0001","title":"https://antonioaurel.github.io/data/data-visualization/recife-history-connections/pages/sources.html","source_type":"url","author":"","year":"","url":"https://antonioaurel.github.io/data/data-visualization/recife-history-connections/pages/sources.html","notes":""}],"edges":[{"target_id":"LC-0408","target_name":"Avenida Herculano Bandeira","target_type":"place","type":"local","strength":1},{"target_id":"LC-0042","target_name":"Banhistas do Pina","target_type":"place","type":"local","strength":1},{"target_id":"LC-0610","target_name":"Boa Vista","target_type":"place","type":"local","strength":1},{"target_id":"LC-0056","target_name":"Brasília Teimosa","target_type":"place","type":"local","strength":1},{"target_id":"LC-0061","target_name":"Cais da Lingueta","target_type":"place","type":"local","strength":1},{"target_id":"LC-0071","target_name":"Capunga","target_type":"place","type":"local","strength":1},{"target_id":"LC-0076","target_name":"Casa de Banhos","target_type":"place","type":"local","strength":1},{"target_id":"LC-0135","target_name":"Fortaleza do Buraco","target_type":"place","type":"local","strength":1},{"target_id":"LC-0179","target_name":"Igreja dos Capuchinhos","target_t