{"id":"LC-0333","name":"Sítio da Trindade","type":"local","subtype":"Sítio Histórico","description":"Sitio da Trindade é um sitio histórico localizado em Casa Amarela, no Recife/Pernambuco. Relaciona-se a Estrada do Arraial, Invasão Holandesa, Matias de Albuquerque e Henrique Dias, indicando sua função como ponto de articulação entre território, memória e vida urbana. Sua presença ajuda a compreender como espaços públicos, edifícios, instituições e equipamentos acumulam camadas de uso social, homenagens e transformações ao longo do tempo. Sitio da Trindade funciona como referência para compreender a experiência cotidiana do Recife com processos históricos, culturais e políticos mais amplos.","period":"","reference_location":"Casa Amarela","municipality":"Recife","neighborhood":"Casa Amarela","image":"","aliases":[],"sources":[{"id":"FT-0001","title":"https://antonioaurel.github.io/data/data-visualization/recife-history-connections/pages/sources.html","source_type":"url","author":"","year":"","url":"https://antonioaurel.github.io/data/data-visualization/recife-history-connections/pages/sources.html","notes":""}],"edges":[{"target_id":"LC-0076","target_name":"Casa de Banhos","target_type":"local","type":"local","strength":1},{"target_id":"LC-0385","target_name":"Cemitério dos Ingleses","target_type":"local","type":"local","strength":1},{"target_id":"LC-0118","target_name":"Edifício Acaiaca","target_type":"local","type":"local","strength":1},{"target_id":"LC-0115","target_name":"Edifício Holiday","target_type":"local","type":"local","strength":1},{"target_id":"LC-0402","target_name":"Estrada do Arraial","target_type":"local","type":"local","strength":1},{"target_id":"PE-AUS-0093","target_name":"Henrique Dias","target_type":"personagem","type":"person","strength":1},{"target_id":"LC-0395","target_name":"Hotel Central","target_type":"local","type":"local","strength":1},{"target_id":"FH-0185","target_name":"Invasão Holandesa","target_type":"evento","type":"local","strengt