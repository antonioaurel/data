{"id":"LC-0085","name":"Clube Internacional do Recife","type":"place","subtype":"Clube","description":"Clube Intercional do Recife é um clube localizado em Madalena, no Recife/Pernambuco. O registro se relaciona à cultura popular, à sociabilidade de bairro e às manifestações festivas que marcam a identidade de Pernambuco. aparece associado a Roberto Burle Marx e Praça Euclides da Cunha, mostrando como clubes, agremiações e espaços coletivos conectam música, carnaval, esporte, lazer e memória comunitária. Clube Intercional do Recife ajuda a revelar a cidade como rede viva de encontros e tradições.","period":"","reference_location":"Madalena","municipality":"Recife","neighborhood":"Madalena","image":"","has_geo":false,"aliases":[],"sources":[{"id":"FT-0001","title":"https://antonioaurel.github.io/data/data-visualization/recife-history-connections/pages/sources.html","source_type":"url","author":"","year":"","url":"https://antonioaurel.github.io/data/data-visualization/recife-history-connections/pages/sources.html","notes":""}],"edges":[{"target_id":"LC-0030","target_name":"Avenida Caxangá","target_type":"place","type":"local","strength":1},{"target_id":"LC-0050","target_name":"Batutas de São José","target_type":"place","type":"local","strength":1},{"target_id":"LC-0058","target_name":"Cabanga Iate Clube","target_type":"place","type":"local","strength":1},{"target_id":"LC-0086","target_name":"Clube Náutico Capibaribe","target_type":"place","type":"local","strength":1},{"target_id":"LC-0087","target_name":"Clube Português","target_type":"place","type":"local","strength":1},{"target_id":"LC-0125","target_name":"Estrada dos Remédios","target_type":"place","type":"local","strength":1},{"target_id":"LC-0394","target_name":"Madeiras do Rosarinho","target_type":"place","type":"local","strength":1},{"target_id":"LC-0388","target_name":"Maracatu Cruzeiro do Forte","target_type":"place","type":"local","strength":1},{"target_id":"LC-0225","target_name":"Mercado da Madalena","targ