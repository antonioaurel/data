{"id":"LC-0308","name":"Rio Capibaribe","type":"place","subtype":"Rio","description":"Rio Capibaribe é um rio situado no Recife/Pernambuco. Relaciona-se a Rio Beberibe, Prefeitura do Recife, Ponte do Limoeiro, Enchentes do Recife, Casa de Banhos e Bacia do Pina, indicando sua função como ponto de articulação entre território, memória e vida urbana. Sua presença ajuda a compreender como espaços públicos, edifícios, instituições e equipamentos acumulam camadas de uso social, homenagens e transformações ao longo do tempo. Rio Capibaribe funciona como referência para compreender a experiência cotidiana do Recife com processos históricos, culturais e políticos mais amplos.","period":"","reference_location":"","municipality":"Pernambuco","neighborhood":"","image":"","has_geo":false,"aliases":[],"sources":[{"id":"FT-0001","title":"https://antonioaurel.github.io/data/data-visualization/recife-history-connections/pages/sources.html","source_type":"url","author":"","year":"","url":"https://antonioaurel.github.io/data/data-visualization/recife-history-connections/pages/sources.html","notes":""}],"edges":[{"target_id":"LC-0009","target_name":"Aeroclube de Pernambuco","target_type":"place","type":"local","strength":1},{"target_id":"LC-0010","target_name":"Aeroporto Internacional do Recife","target_type":"place","type":"local","strength":1},{"target_id":"LC-AUS-0023","target_name":"Bacia do Pina","target_type":"place","type":"local","strength":1},{"target_id":"LC-0063","target_name":"Cais José Estelita","target_type":"place","type":"local","strength":1},{"target_id":"LC-0064","target_name":"Cais Martins de Barros","target_type":"place","type":"local","strength":1},{"target_id":"LC-0060","target_name":"Cais da Alfândega","target_type":"place","type":"local","strength":1},{"target_id":"LC-0061","target_name":"Cais da Lingueta","target_type":"place","type":"local","strength":1},{"target_id":"LC-0370","target_name":"Cais de Santa Rita","target_type":"place","type":"local","strength":