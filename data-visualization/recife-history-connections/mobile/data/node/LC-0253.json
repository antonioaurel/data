{"id":"LC-0253","name":"Palácio do Campo das Princesas","type":"local","subtype":"Instituição","description":"O Palácio do Campo das Princesas é a sede do Governo de Pernambuco, localizado na Praça da República, no bairro de Santo Antônio. O edifício é um dos principais símbolos do poder político estadual e reúne memórias de governos, decisões administrativas, cerimônias públicas e episódios da história republicana. Seu nome e sua localização o vinculam ao conjunto monumental do centro do Recife. conecta-se a governadores, políticos e instituições, funcionando como registro central da história administrativa e política pernambucana.","period":"","reference_location":"Santo Antônio","municipality":"Recife","neighborhood":"Santo Antônio","image":"","aliases":[],"sources":[{"id":"FT-0001","title":"https://antonioaurel.github.io/data/data-visualization/recife-history-connections/pages/sources.html","source_type":"url","author":"","year":"","url":"https://antonioaurel.github.io/data/data-visualization/recife-history-connections/pages/sources.html","notes":""}],"edges":[{"target_id":"LC-0021","target_name":"Arquivo Público","target_type":"local","type":"local","strength":1},{"target_id":"LC-0033","target_name":"Avenida Guararapes","target_type":"local","type":"local","strength":1},{"target_id":"LC-0043","target_name":"Banco do Nordeste","target_type":"local","type":"local","strength":1},{"target_id":"LC-0068","target_name":"Capela Dourada","target_type":"local","type":"local","strength":1},{"target_id":"LC-0415","target_name":"Centro de Estudos e Sistemas Avançados do Recife (C.E.S.A.R)","target_type":"local","type":"local","strength":1},{"target_id":"LC-0098","target_name":"Convento de Santo Antônio","target_type":"local","type":"local","strength":1},{"target_id":"LC-0107","target_name":"Diário de Pernambuco","target_type":"local","type":"local","strength":1},{"target_id":"LC-0114","target_name":"Edifício dos Correios","target_type":"local","type":"local","strength":1},{