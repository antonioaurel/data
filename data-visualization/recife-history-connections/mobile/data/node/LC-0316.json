{"id":"LC-0316","name":"Rua do Apolo","type":"local","subtype":"Logradouro","description":"Rua do Apolo é um logradouro localizado em Recife Antigo, no Recife/Pernambuco. Como via urbana, ajuda a compreender a circulação, a ocupação dos bairros e a permanência de homenagens na paisagem da cidade. aparece associado a Teatro Apolo, Avenida Barbosa Lima e Rua da Guia, indicando sua função como ponto de ligação entre território, memória e vida cotidiana. o registro permite observar como nomes de ruas e avenidas conectam personagens, instituições, eventos e transformações do Recife ao longo do tempo.","period":"","reference_location":"Recife Antigo","municipality":"Recife","neighborhood":"Recife Antigo","image":"","aliases":[],"sources":[{"id":"FT-0001","title":"https://antonioaurel.github.io/data/data-visualization/recife-history-connections/pages/sources.html","source_type":"url","author":"","year":"","url":"https://antonioaurel.github.io/data/data-visualization/recife-history-connections/pages/sources.html","notes":""}],"edges":[{"target_id":"LC-0022","target_name":"Arsenal da Marinha","target_type":"local","type":"local","strength":1},{"target_id":"LC-0025","target_name":"Avenida 17 de Agosto","target_type":"local","type":"local","strength":1},{"target_id":"LC-0378","target_name":"Avenida Abdias de Carvalho","target_type":"local","type":"local","strength":1},{"target_id":"LC-0026","target_name":"Avenida Agamenon Magalhães","target_type":"local","type":"local","strength":1},{"target_id":"LC-0028","target_name":"Avenida Barbosa Lima","target_type":"local","type":"local","strength":1},{"target_id":"LC-0027","target_name":"Avenida Barão de Souza Leão","target_type":"local","type":"local","strength":1},{"target_id":"LC-0029","target_name":"Avenida Boa Viagem","target_type":"local","type":"local","strength":1},{"target_id":"LC-0030","target_name":"Avenida Caxangá","target_type":"local","type":"local","strength":1},{"target_id":"LC-0036","target_name":"Avenida Marquês de Ol