{"id":"LC-0358","name":"Cais do Sertão","type":"place","subtype":"Museu/Centro Cultural","description":"O Centro Cultural Cais do Sertão é um dos museus mais modernos e imersivos do Brasil, instalado à beira-mar no antigo Armazém 10 do Porto do Recife. O espaço propõe uma viagem poética e sensorial pela cultura nordestina, tendo como fio condutor a vida e a obra de Luiz Gonzaga, o Rei do Baião.","period":"","reference_location":"Recife Antigo","municipality":"Recife","neighborhood":"Recife Antigo","image":"","has_geo":false,"aliases":["Museu Cais do Sertão"],"sources":[{"id":"FT-0005","title":"https://pt.wikipedia.org/wiki/Museu_Cais_do_Sert%C3%A3o","source_type":"url","author":"","year":"","url":"https://pt.wikipedia.org/wiki/Museu_Cais_do_Sert%C3%A3o","notes":""},{"id":"FT-0001","title":"https://antonioaurel.github.io/data/data-visualization/recife-history-connections/pages/sources.html","source_type":"url","author":"","year":"","url":"https://antonioaurel.github.io/data/data-visualization/recife-history-connections/pages/sources.html","notes":""}],"edges":[{"target_id":"LC-AUS-0023","target_name":"Bacia do Pina","target_type":"place","type":"unresolved","strength":1},{"target_id":"PE-AUS-0066","target_name":"Dominguinhos","target_type":"person","type":"person","strength":1},{"target_id":"PE-AUS-0080","target_name":"Francisco Brennand","target_type":"person","type":"unresolved","strength":1},{"target_id":"LC-0183","target_name":"Instituto Ricardo Brennand","target_type":"place","type":"unresolved","strength":1},{"target_id":"PE-AUS-0117","target_name":"Luiz Gonzaga","target_type":"person","type":"person","strength":1},{"target_id":"LC-0241","target_name":"Museu do Homem do Nordeste","target_type":"place","type":"unresolved","strength":1},{"target_id":"LC-0463","target_name":"O Forró","target_type":"place","type":"local","strength":1},{"target_id":"LC-0337","target_name":"Teatro Apolo","target_type":"place","type":"unresolved","strength":1}]}