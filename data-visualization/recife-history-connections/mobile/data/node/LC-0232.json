{"id":"LC-0232","name":"Monumento a Frei Caneca","type":"place","subtype":"Monumento","description":"Monumento a Frei Caneca é um monumento localizado em São José, no Recife/Pernambuco. Relaciona-se a Frei Caneca e Forte das Cinco Pontas, indicando sua função como ponto de articulação entre território, memória e vida urbana. Sua presença ajuda a compreender como espaços públicos, edifícios, instituições e equipamentos acumulam camadas de uso social, homenagens e transformações ao longo do tempo. Monumento a Frei Caneca funciona como referência para compreender a experiência cotidiana do Recife com processos históricos, culturais e políticos mais amplos.","period":"","reference_location":"São José","municipality":"Recife","neighborhood":"São José","image":"","aliases":[],"sources":[{"id":"FT-0001","title":"https://antonioaurel.github.io/data/data-visualization/recife-history-connections/pages/sources.html","source_type":"url","author":"","year":"","url":"https://antonioaurel.github.io/data/data-visualization/recife-history-connections/pages/sources.html","notes":""}],"edges":[{"target_id":"LC-0031","target_name":"Avenida Dantas Barreto","target_type":"place","type":"local","strength":1},{"target_id":"LC-0063","target_name":"Cais José Estelita","target_type":"place","type":"local","strength":1},{"target_id":"LC-0064","target_name":"Cais Martins de Barros","target_type":"place","type":"local","strength":1},{"target_id":"LC-0066","target_name":"Camelódromo","target_type":"place","type":"local","strength":1},{"target_id":"LC-0075","target_name":"Casa da Cultura","target_type":"place","type":"local","strength":1},{"target_id":"LC-0136","target_name":"Forte das Cinco Pontas","target_type":"place","type":"local","strength":1},{"target_id":"PE-AUS-0084","target_name":"Frei Caneca","target_type":"person","type":"person","strength":1},{"target_id":"LC-0233","target_name":"Monumento aos Aviadores Portugueses","target_type":"place","type":"local","strength":1},{"target_id":"LC-0