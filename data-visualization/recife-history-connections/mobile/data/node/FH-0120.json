{"id":"FH-0120","name":"Esgotamento Sanitário","type":"historical_fact","subtype":"Ambiente","description":"Esgotamento Sanitário é um ambiente relacionado à história de Pernambuco. Relaciona-se a Estação de Esgotos do Capanga, formando uma ponte entre acontecimentos, espaços urbanos e personagens públicos. O registro ajuda a contextualizar disputas políticas, mudanças sociais, conflitos, práticas culturais ou transformações ambientais que marcaram a formação pernambucana. Esgotamento Sanitário funciona como eixo narrativo para compreender como eventos coletivos deixam marcas na paisagem, na memória pública e nas conexões entre diferentes pontos do território.","period":"","reference_location":"","municipality":"Pernambuco","neighborhood":"","image":"","has_geo":false,"aliases":[],"sources":[{"id":"FT-0001","title":"https://antonioaurel.github.io/data/data-visualization/recife-history-connections/pages/sources.html","source_type":"url","author":"","year":"","url":"https://antonioaurel.github.io/data/data-visualization/recife-history-connections/pages/sources.html","notes":""}],"edges":[{"target_id":"FH-0067","target_name":"Cangaço","target_type":"historical_fact","type":"historical_event","strength":1},{"target_id":"FH-0069","target_name":"Capitanias Hereditárias","target_type":"historical_fact","type":"historical_event","strength":1},{"target_id":"LC-0079","target_name":"Cemitério de Santo Amaro","target_type":"place","type":"historical_event","strength":1},{"target_id":"FH-0093","target_name":"Coluna Prestes","target_type":"historical_fact","type":"historical_event","strength":1},{"target_id":"FH-0094","target_name":"Companhia das Índias Ocidentais","target_type":"historical_fact","type":"historical_event","strength":1},{"target_id":"FH-0095","target_name":"Confederação do Equador","target_type":"historical_fact","type":"historical_event","strength":1},{"target_id":"FH-0097","target_name":"Convenção de Beberibe","target_type":"historical_fact","type":"historical_e