{"id":"LC-0425","name":"Basílica de Nossa Senhora do Carmo","type":"place","subtype":"Templo Religioso","description":"Foto de Bruno Albuquerque. A Basílica e Convento de Nossa Senhora do Carmo é um conjunto arquitetônico católico pertencente à Ordem Carmelita, localizado no Recife, bairro de Santo Antônio. Suas obras foram iniciadas em 1665 e concluídas somente em 1767. A igreja segue o estilo barroco.","period":"","reference_location":"São José","municipality":"Recife","neighborhood":"São José","image":"https://upload.wikimedia.org/wikipedia/commons/thumb/a/a2/Igreja_da_Ordem_Terceira_de_Nossa_Senhora_do_Carmo_em_Recife.JPG/1200px-Igreja_da_Ordem_Terceira_de_Nossa_Senhora_do_Carmo_em_Recife.JPG","has_geo":false,"aliases":["Basílica do Carmo"],"sources":[{"id":"FT-0001","title":"https://antonioaurel.github.io/data/data-visualization/recife-history-connections/pages/sources.html","source_type":"url","author":"","year":"","url":"https://antonioaurel.github.io/data/data-visualization/recife-history-connections/pages/sources.html","notes":""}],"edges":[{"target_id":"LC-0068","target_name":"Capela Dourada","target_type":"place","type":"local","strength":1},{"target_id":"LC-0098","target_name":"Convento de Santo Antônio","target_type":"place","type":"local","strength":1},{"target_id":"LC-0101","target_name":"Cruz do Patrão","target_type":"place","type":"local","strength":1},{"target_id":"LC-0165","target_name":"Igreja da Capunga","target_type":"place","type":"local","strength":1},{"target_id":"LC-0166","target_name":"Igreja da Conceição dos Militares","target_type":"place","type":"local","strength":1},{"target_id":"LC-0167","target_name":"Igreja da Madre de Deus","target_type":"place","type":"local","strength":1},{"target_id":"LC-0168","target_name":"Igreja da Várzea (Paróquia Nossa Sra. do Rosário)","target_type":"place","type":"local","strength":1},{"target_id":"LC-0169","target_name":"Igreja de Belém","target_type":"place","type":"local","strength":1},{"target_id":"LC